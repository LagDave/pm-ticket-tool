# PM Tool — environment template. Copy to .env and fill in.
# Required config is validated at startup; the server fails fast if any is
# missing or malformed (§5.6).

NODE_ENV=development
PORT=4222

# Generic Postgres connection string. Local Docker Postgres maps host :8765.
# In prod this is Neon's pooled, SSL connection string.
DATABASE_URL=postgresql://pmtool:pmtool_dev@localhost:8765/pm_tool

# TLS for the DB connection. false locally; true for Neon (prod).
DATABASE_SSL=false
# Keep certificate verification ON (§5.4). Set false only for a managed
# provider whose cert can't chain to the default CA bundle.
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Knex pool sizing profile (§10.6). "persistent" (default, used locally and on a
# long-running Node host) keeps a warm pool (min 2, max 10). "serverless" (set in
# the Vercel env) uses tiny bounds (min 0, max 1) so many warm function instances
# don't exhaust Neon's connection limit. Leave unset locally.
DATABASE_POOL_MODE=persistent

# Single-service runtime flags (Railway, deploy spec Rev 2). Both default ON when
# NODE_ENV=production and OFF otherwise, so local dev is unchanged; an explicit
# value here always wins. Leave unset locally.
#   SERVE_STATIC=true     -> Express serves the built SPA (frontend/dist) + a
#                            client-routing catch-all from the same origin, and
#                            mounts the API under /api. In dev the Vite dev server
#                            owns the SPA, so leave this off (default).
#   RUN_SCOUT_WORKER=true -> drain the scout_jobs queue IN-PROCESS (§21) instead
#                            of via cron. Locally use `npm run scout:work` instead.
SERVE_STATIC=
RUN_SCOUT_WORKER=

# Comma-separated CORS allow-list (no wildcard in prod, §11.4).
CORS_ORIGINS=http://localhost:4221

LOG_LEVEL=info

# Server-side only — never shipped to the browser (§5.1, §17.3).
# Empty in foundation; injected later for the interview engine.
ANTHROPIC_API_KEY=

# Optional GitHub token for the code scout (spec 5). Server-side only — never
# shipped to the browser (§5.1, §17.3). LEAVE EMPTY for public-repo scans: the
# GitHub REST API works unauthenticated on public repos. A token is required
# only for PRIVATE repos or higher rate limits. Scanning a private repo (or the
# real Azure target survey360, a separate Azure provider deferred to a later
# spec) needs a credential.
GITHUB_TOKEN=

# Shared secret guarding the internal scout-processor trigger
# (POST /internal/scout/process), which Vercel Cron hits to drain the scout job
# queue (deploy runtime Option C, §21). Server-side only — never shipped to the
# browser (§5.1, §17.3) and never logged (§5.3). When EMPTY the HTTP trigger is
# fail-closed (refuses every caller) and the queue is drained only by the local
# worker (`npm run scout:work`); set a strong random value in any environment
# that exposes the cron trigger (e.g. production on Vercel).
SCOUT_WORKER_SECRET=
